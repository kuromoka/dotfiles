{
  "permissions": {
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Glob(~/.ssh/**)",
      "Grep(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Write(~/.gnupg/**)",
      "Glob(~/.gnupg/**)",
      "Grep(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Write(~/.aws/**)",
      "Glob(~/.aws/**)",
      "Grep(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Edit(~/.config/gcloud/**)",
      "Write(~/.config/gcloud/**)",
      "Glob(~/.config/gcloud/**)",
      "Grep(~/.config/gcloud/**)",
      "Read(~/.azure/**)",
      "Edit(~/.azure/**)",
      "Write(~/.azure/**)",
      "Glob(~/.azure/**)",
      "Grep(~/.azure/**)",
      "Read(~/.kube/**)",
      "Edit(~/.kube/**)",
      "Write(~/.kube/**)",
      "Glob(~/.kube/**)",
      "Grep(~/.kube/**)",
      "Read(~/.netrc)",
      "Edit(~/.netrc)",
      "Write(~/.netrc)",
      "Read(~/.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/**.env)",
      "Write(~/.env)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/**.env)",
      "Edit(~/.env)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/**.env)",
      "Read(~/.bash_history)",
      "Read(~/.zsh_history)",
      "Read(~/.docker/config.json)",
      "Edit(~/.docker/config.json)",
      "Write(~/.docker/config.json)"
    ]
  },
  "model": "opusplan",
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "language": "japanese"
}
